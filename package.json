{
  "name": "bmad-todo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail \"pnpm --filter @bmad-todo/api dev\" \"pnpm --filter @bmad-todo/web dev\"",
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "pnpm": {
    "overrides": {
      "resolve": "^1.22.8"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.25.1",
    "eslint-plugin-import": "^2.31.0",
    "globals": "^17.5.0",
    "jsdom": "^29.1.0",
    "solid-js": "^1.9.5",
    "prettier": "^3.5.3",
    "fake-indexeddb": "^6.0.0",
    "fast-check": "^3.23.0",
    "tsx": "^4.19.4",
    "typescript": "^5.7.3",
    "vite-plugin-solid": "^2.11.6",
    "vitest": "^3.1.2"
  }
}
