{
  "name": "bmad-todo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm --filter @bmad-todo/api dev & pnpm --filter @bmad-todo/web dev",
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@playwright/test": "^1.52.0",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "eslint": "^9.25.1",
    "globals": "^17.5.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.7.3",
    "vitest": "^3.1.2"
  }
}
